; ============================================================================
; ReRAM configuration for a Graph Accelerator Engine
; Each crossbar is a 128-wordline x 128-bitline (128x128) ReRAM array.
;
; TOPOLOGY:
;   CHANNELS    = 1  (one graph engine)
;   RANKS       = 1
;   BANKS       = 4  <-- Number of crossbars per engine. Change this value
;                        to model a different number of crossbars (e.g., 1, 4, 8)
;   ROWS        = 128  (128 wordlines per crossbar)
;   MATHeight   = 128  --> exactly ONE subarray per bank = one 128x128 crossbar
;   COLS        = 16   (128 bitlines / DeviceWidth 8 = 16 column addresses)
;
; CAPACITY per crossbar: 128 rows x 16 cols x 8 B = 16 KB
; TOTAL capacity:        BANKS x 16 KB = 64 KB (for BANKS=4)
;
; Per-access latency and energy are reported as:
;   averageReadLatency  / averageWriteLatency  -- at the controller (cycles)
;   readEnergyPerAccess / writeEnergyPerAccess -- at the subarray (nJ)
; ============================================================================

;================================================================================
; Interface

; 400 MHz clock (2.5 ns/cycle)
CLK 400
RATE 2
BusWidth 64
DeviceWidth 8
CPUFreq 2000
;================================================================================

;================================================================================
; Organization -- model each bank as one independent 128x128 crossbar

CHANNELS 1

RANKS 1

; === Number of crossbars per engine ===
; Change BANKS to set how many crossbars the engine contains (e.g., 1, 4, 8, 16)
BANKS 4

; 128 wordlines per crossbar
ROWS 128

; 128 bitlines / DeviceWidth(8) = 16 column addresses
COLS 16

; MATHeight = ROWS --> exactly one 128x128 subarray per bank
MATHeight 128

; Row buffer covers the full width of one crossbar row
RBSize 1

; No refresh in ReRAM
UseRefresh false
BanksPerRefresh 1
RefreshRows 1
DelayedRefreshThreshold 1
;================================================================================

;================================================================================
; Timing (in memory cycles @ 400 MHz, based on ISSCC 2012 RRAM macro)
;
; Key access latency breakdown:
;   Read:  tRCD(10) + tCAS(6) + tBURST(4) = 20 cycles = 50 ns
;   Write: tRCD(10) + tCWD(4) + tBURST(4) + tWP(4) = 22 cycles = 55 ns

tBURST 4   ; Data burst length
tCMD   1   ; Address bus command cycle
tRAS   0   ; No row restoration in ReRAM
tRCD   10  ; Row-to-Column Delay: 25 ns @ 400 MHz
tWP    4   ; Write pulse: ~10 ns @ 400 MHz
tRP    1   ; Precharge (writes occur in-place, minimal time needed)
tCAS   6   ; Column Access Strobe: slightly longer due to sense amp path
tAL    0
tCCD   2

tCWD   4   ; CAS Write Delay: 10 ns
tWTR   3   ; Write-to-Read turnaround: 7.5 ns
tWR    0   ; Write-to-Precharge (not needed for ReRAM)
tRTRS  1
tRTP   3   ; Read-to-Precharge
tOST   0   ; No ODT

tRRDR  4
tRRDW  4
RAW    4
tRAW   20

tRDPDEN 10
tWRPDEN 12
tWRAPDEN 12
tPD    1
tXP    3
tXPDLL 200000

tRFC   100
tREFW  42666667
;================================================================================

;================================================================================
; Energy parameters (from RRAM ISSCC 2012, nJ per access)
;
;   Erd      = read energy per mat access      = 0.0812 nJ
;   Eopenrd  = open-row (row-buffer-hit) read  = 0.0016 nJ
;   Ewr      = write energy (SET or RESET)     = 1.6848 nJ
;   Ewrpb    = write energy per bit            = 0.000202 nJ

EnergyModel energy

Erd      0.081200
Eopenrd  0.001616
Ewr      1.684811
Ewrpb    = 0.000202

Eleak    3120.202   ; Leakage power in mW (mJ/s)

Epdpf 0
Epdps 0
Epda  0
Eref  0

Voltage 1.8
;================================================================================

;================================================================================
; Memory controller

MEM_CTL FRFCFS-WQF

; Open-page policy (exploit row-buffer locality within a crossbar row)
ClosePage 0

; Bank-first round-robin scheduling
ScheduleScheme 2

; Address mapping: Row, Rank, Bank, Channel, Column
AddressMappingScheme R:RK:BK:CH:C

INTERCONNECT OffChipBus

; Queue sizes (small, matching a lightweight engine)
ReadQueueSize  16
WriteQueueSize 16
HighWaterMark  16
LowWaterMark   8
;================================================================================

;================================================================================
; Simulation control
PrintGraphs false
PrintPreTrace false
PreTraceFile reram_engine.trace
EchoPreTrace false
PeriodicStatsInterval 0

TraceReader NVMainTrace
;================================================================================
