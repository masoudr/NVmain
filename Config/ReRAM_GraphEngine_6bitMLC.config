; ============================================================================
;  ReRAM Graph Accelerator Engine  --  NVMain configuration
;  Cell type: 6-bit MLC (Multi-Level Cell, 64 resistance levels per cell)
; ============================================================================
;
;  This file models ONE graph engine that contains a configurable number
;  of independent square ReRAM crossbar arrays.
;
;  Two parameters are intended to be varied (via the run_reram.py script
;  or NVMain `PARAM=value` CLI overrides):
;
;     SIZE   = NxN     -- Crossbar dimensions (e.g. 32x32, 128x128, 256x256).
;                         Handled by run_reram.py: sets ROWS, MATHeight,
;                         COLS, and scales Erd/Ewr/Eopenrd accordingly.
;     BANKS  = N       -- Number of crossbars per engine (one bank == one
;                         independent crossbar).
;
;  Defaults below: 4 crossbars of 128x128.
;  Timing and energy are scaled from the Panasonic ISSCC 2012 SLC ReRAM
;  macro to a 6-bit MLC device with two circuit-level optimizations:
;    - Read  : 2-step hierarchical sensing (coarse 3-bit + fine 3-bit in
;              parallel sense amps) cuts tCAS to ~2x SLC instead of 4x.
;    - Write : Predictive ISPP -- a calibration table pre-positions the
;              first pulse near the target level, reducing verify iterations
;              from ~25 to ~8; tWP ~30x SLC instead of ~100x.
;    - Energy: 2x read, 5x write relative to SLC baseline.
; ============================================================================


;================================================================================
; CLOCK AND BUS
;================================================================================
;
; CLK      -- Memory / engine clock frequency, in MHz.
;             The graph engine runs at 400 MHz, so 1 cycle = 1/400 MHz = 2.5 ns.
;             ALL latencies reported by NVMain are in memory cycles (CLK domain).
;
; CPUFreq  -- "Issuing" clock frequency, in MHz. NVMain only uses the ratio
;             CLK/CPUFreq to convert the optional `cycles` CLI argument from
;             host-cycle units into memory cycles. It does NOT change trace
;             timestamps or reported per-access latencies.
;             For a self-contained graph engine where the engine itself issues
;             requests, set CPUFreq == CLK so 1 issue cycle == 1 memory cycle.
;
; RATE     -- Data rate per clock edge. 1 = SDR, 2 = DDR. We use SDR for
;             a custom on-die engine-to-crossbar bus.
;
; BusWidth / DeviceWidth
;          -- Bus is BusWidth bits wide, formed by (BusWidth / DeviceWidth)
;             devices. For SIZE = NxN, each device sees N bitlines.
;             With BusWidth=64, DeviceWidth=8 we have 8 devices per access;
;             the per-device crossbar size is controlled by ROWS/MATHeight/COLS.

CLK         400
CPUFreq     400
RATE        1
BusWidth    64
DeviceWidth 8


;================================================================================
; ORGANIZATION  --  One bank == one independent NxN crossbar
;================================================================================
;
; The graph engine has CHANNELS x RANKS x BANKS independent crossbars. We
; collapse to a single channel/rank so BANKS == "number of crossbars per
; engine". Each bank holds exactly one subarray (one crossbar) because
; MATHeight == ROWS.

CHANNELS    1
RANKS       1

; ---- Number of crossbars per engine ----------------------------------
BANKS       4

; ---- Crossbar geometry  (128x128 default) ----------------------------
;       ROWS      = N      (number of wordlines)
;       COLS      = N / DeviceWidth   (column addresses; bitlines / DeviceWidth)
;       MATHeight = ROWS              (forces exactly one subarray per bank)
ROWS        128
COLS        16
MATHeight   128

; Row buffer holds one full crossbar row
RBSize      1

; ReRAM is non-volatile; no refresh
UseRefresh              false
BanksPerRefresh         1
RefreshRows             1
DelayedRefreshThreshold 1


;================================================================================
; TIMING  (all values in memory cycles, 1 cycle = 2.5 ns @ 400 MHz)
;================================================================================
;
; Optimized 6-bit MLC timing:
;
;   Read  : tRCD + tCAS + tBURST       = 16 + 12 + 4 = 32 cycles = 80 ns
;             tRCD  16 cy (40 ns) -- optimized WL driver; slightly less settling
;                                   needed because predictive ISPP keeps cell
;                                   resistance tightly distributed
;             tCAS  12 cy (30 ns) -- 2-step hierarchical sensing:
;                                   coarse 3-bit (parallel 8-ref) + fine 3-bit
;                                   (parallel 8-ref) in two pipelined phases,
;                                   each ~15 ns  => 2x SLC instead of 4x
;
;   Write : tRCD + tCWD + tBURST + tWP = 16 + 6 + 4 + 120 = 146 cycles = 365 ns
;             tWP  120 cy (300 ns) -- predictive ISPP:
;                                   calibration table sets first pulse near
;                                   target level; only ~8 verify iterations
;                                   needed vs ~25 in naive IWV
;
; The controller reports the average actually achieved (which is slightly
; higher because of bus / command-queue serialization).

tBURST  4    ; Data burst length (cycles)
tCMD    1    ; Address-bus command cycle
tRAS    0    ; No row restoration in ReRAM
tRCD   16    ; Row-to-Column delay  =  40 ns  (1.6x SLC; tighter R distribution)
tWP   120    ; Write (predictive ISPP total) = 300 ns  (~8 iterations for 64 levels)
tRP     4    ; Precharge             =  10 ns
tCAS   12    ; Column-access strobe  =  30 ns  (2x SLC; 2-step hierarchical sensing)
tAL     0
tCCD    4

tCWD    6    ; CAS write delay       =  15 ns
tWTR    5    ; Write-to-read turnaround
tWR     0    ; Write-to-precharge (not needed for ReRAM)
tRTRS   1
tRTP    4    ; Read-to-precharge
tOST    0    ; No ODT

tRRDR   5
tRRDW   5
RAW     5
tRAW   24

tRDPDEN  16
tWRPDEN 130    ; tWP + overhead
tWRAPDEN 130
tPD      1
tXP      3
tXPDLL   200000

; Refresh values unused (UseRefresh=false) but must be valid
tRFC    100
tREFW   42666667


;================================================================================
; ENERGY  (per-access values in nJ, 6-bit MLC optimized from ISSCC 2012 SLC macro)
;================================================================================
;
; These values are calibrated for a 128-bitline crossbar (the reference).
; run_reram.py automatically scales them when SIZE=NxN is specified, using
; the linear bitline-count scaling:  E(scaled) = E(ref) * (N / 128).
;
;   Erd      -- read energy per wordline activation  (2x SLC: 2-step hierarchical
;               sensing uses parallel sense amps -- half the reference current
;               compared to naive 4-step sequential)
;   Eopenrd  -- read energy on a row-buffer hit      (2x SLC)
;   Ewr      -- write energy per ISPP sequence       (5x SLC: ~8 iterations;
;               predictive start means each sub-pulse is smaller, and fewer
;               verify reads are needed vs naive IWV)
;   Ewrpb    -- per-bit write savings (write-back)   (5x SLC)
;   Eleak    -- leakage power, in mW (mJ/s)          (array structure unchanged)

EnergyModel  energy

Erd       0.162400
Eopenrd   0.003232
Ewr       8.424055
Ewrpb     0.001010

Eleak     3120.202

Epdpf 0
Epdps 0
Epda  0
Eref  0

Voltage 1.8


;================================================================================
; MLC CELL CONFIGURATION
;================================================================================
;
; MLCLevels    -- bits stored per cell. 6 = 64 resistance levels.
; UniformWrites -- use the uniform IWV write model (required for MLCLevels > 2).
;                  tWP is treated as the total IWV write time per row.

MLCLevels     6
UniformWrites true


;================================================================================
; MEMORY CONTROLLER
;================================================================================

MEM_CTL              FRFCFS-WQF
ClosePage            0                  ; 0 = open-page (exploit row locality)
ScheduleScheme       2                  ; bank-first round-robin
AddressMappingScheme R:RK:BK:CH:C
INTERCONNECT         OffChipBus

; Small queues, suitable for a lightweight engine
ReadQueueSize  16
WriteQueueSize 16
HighWaterMark  16
LowWaterMark    8


;================================================================================
; SIMULATION CONTROL
;================================================================================

PrintGraphs           false
PrintPreTrace         false
PreTraceFile          reram_engine.trace
EchoPreTrace          false
PeriodicStatsInterval 0

TraceReader           NVMainTrace
