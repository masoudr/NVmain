; Custom 32MB ReRAM configuration with 128x128 crossbar arrays
;
; Architecture:
;   - Each subarray is a 128-wordline x 128-bitline crossbar
;   - 1 channel, 1 rank, 4 banks
;   - 512 subarrays per bank (ROWS/MATHeight = 65536/128)
;   - Total capacity: 1 x 1 x 4 x 65536 x 16 x 8 = 32MB
;
; Timing/energy parameters retained from RRAM_ISSCC_2012_4GB.config

;================================================================================
; Interface specifications

; 400 MHz clock (2.5 ns period)
CLK 400

; Data Rate. 1 for SDR, 2 for DDR
RATE 2

; Bus width in bits
BusWidth 64

; Number of bits provided by each device in a rank
; Number of devices = BusWidth / DeviceWidth = 64 / 8 = 8 devices
DeviceWidth 8

; CPU frequency for synchronization ratio
CPUFreq 2000
;================================================================================

;================================================================================
; Memory organization

; 1 channel (single-channel 32MB system)
CHANNELS 1

; 1 rank per channel
RANKS 1

; 4 banks per rank
BANKS 4

; Total rows per bank. With MATHeight=128: 65536/128 = 512 subarrays (crossbars) per bank
ROWS 65536

; Visible columns per bank: 128 bitlines / DeviceWidth(8) = 16 column addresses
COLS 16

; Each crossbar mat has 128 wordlines (rows)
MATHeight 128

; Row buffer granularity. With 128 bitlines -> 16 COLS, set to 1 (full row buffer per access)
RBSize 1

; No refresh needed in RRAM
UseRefresh false

; Assign valid numbers even though unused
BanksPerRefresh 2
RefreshRows 4
DelayedRefreshThreshold 1
;================================================================================

;================================================================================
; Memory device timing parameters (in memory cycles @ 400 MHz)

tBURST 4  ; Length of data burst
tCMD 1    ; Commands are 1 address bus cycle
tRAS 0    ; No row restoration needed
tRCD 10   ; 25ns @ 400 MHz = 10 cycles
tWP 4     ; Write pulse time: 8.2ns @ 400 MHz = 4 cycles
tRP 1     ; Precharge not needed; write-back takes tWP during precharge
tCAS 6    ; Slightly longer due to non-local sense amplifiers
tAL 0
tCCD 2

tCWD 4    ; 10ns
tWTR 3    ; 7.5ns
tWR 0     ; Write-to-precharge not needed
tRTRS 1
tRTP 3    ; Wait for data to leave internal FIFO buffers
tOST 0    ; No ODT circuitry

tRRDR 4
tRRDW 4
RAW 4
tRAW 20

; Powerdown entry and exit timings
tRDPDEN 10
tWRPDEN 12
tWRAPDEN 12
tPD 1
tXP 3
tXPDLL 200000

; Refresh timings (not used in RRAM)
tRFC 100
tREFW 42666667
;================================================================================

;================================================================================
; Memory device energy parameters (nJ, from RRAM_ISSCC_2012)

EnergyModel energy

; Read energy from a single mat
Erd 0.081200

; Open-page read energy
Eopenrd 0.001616

; Write energy (SET or RESET)
Ewr 1.684811

; Subarray write energy per bit
Ewrpb = 0.000202

; Leakage energy in 1 second (mJ)
Eleak 3120.202

Epdpf 0
Epdps 0
Epda 0
Eref 0

Voltage 1.8
;================================================================================

;================================================================================
; Memory controller parameters

MEM_CTL FRFCFS-WQF

; Open-page row buffer management
ClosePage 0

; Bank-first round-robin scheduling
ScheduleScheme 2

; Address mapping
AddressMappingScheme R:RK:BK:CH:C

; Off-chip interconnect (2D)
INTERCONNECT OffChipBus

; FRFCFS-WQF queue parameters
ReadQueueSize 32
WriteQueueSize 32
HighWaterMark 32
LowWaterMark 16
;================================================================================

;================================================================================
; Simulation control

PrintGraphs false
PrintPreTrace false
PreTraceFile pcm.trace
EchoPreTrace false
PeriodicStatsInterval 100000000

TraceReader NVMainTrace
;================================================================================
